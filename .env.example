# =============================================================================
# .env.example — Copy thành .env rồi điền giá trị thật.
# .env KHÔNG được commit (đã có trong .gitignore).
# Trên Colab, dùng %%writefile .env rồi paste nội dung đã điền.
# =============================================================================

# -----------------------------------------------------------------------------
HF_TOKEN=hf_your_hf_token

HF_DATASET_REPO=ThinhDao/TempoRun2025_UIT

# Tên file zip bên trong repo (mặc định: tên zip gốc)
HF_DATASET_FILE=tempo-run-2025-run-with-ai-break-limits.zip

# Model repo (sẽ tạo khi push lần đầu ở Bước 7 trong COLAB_GUIDE.md)
HF_REPO=your_hf_username/temprun-qwen3-0_6b

# -----------------------------------------------------------------------------
# Alibaba Cloud DashScope (OpenAI-compatible endpoint)
# Đăng ký free 1M token: https://dashscope.console.aliyun.com/
# Tạo API key ở: https://dashscope.console.aliyun.com/apiKey
# Dùng để gọi qwen3-max-preview / qwen3.6-max-preview / qwen3.7-max-preview
# cho data enrichment (paraphrase + explanation + sinh câu hỏi mới).
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=sk-your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-max-preview

# -----------------------------------------------------------------------------
# Google Drive (chỉ dùng trên Colab để persist checkpoint qua các session)
# Để trống nếu không mount Drive.
# -----------------------------------------------------------------------------
DRIVE_ROOT=/content/drive/MyDrive/temprun_runs
